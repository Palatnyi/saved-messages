BOT_TOKEN=your_telegram_bot_token_here

# Render Postgres — use either DATABASE_URL or individual fields
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname

# AES-256-GCM key — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_char_hex_string_here

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

ANTHROPIC_API_KEY=you_anthropic_key_here
CLAUDE_MODEL=claude-haiku-4-5-20251001
